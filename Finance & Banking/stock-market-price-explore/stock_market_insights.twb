      <column caption='Up/Down Day - AAPL' datatype='string' name='[Calculation_1953999299194249217]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([close_AAPL]) &gt; LOOKUP(SUM([close_AAPL]), -1)&#13;&#10;THEN &quot;Up&quot;&#13;&#10;ELSE &quot;Down&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Up/Down Day - AMZN' datatype='string' name='[Calculation_1953999299196166146]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([close_AMZN]) &gt; LOOKUP(SUM([close_AMZN]), -1)&#13;&#10;THEN &quot;Up&quot;&#13;&#10;ELSE &quot;Down&quot;&#13;&#10;END'>
