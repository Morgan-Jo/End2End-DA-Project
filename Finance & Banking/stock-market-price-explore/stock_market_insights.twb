      <column caption='Up/Down Day - GOOGL' datatype='string' name='[Calculation_1953999299196239875]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([close_GOOGL]) &gt; LOOKUP(SUM([close_GOOGL]), -1)&#13;&#10;THEN &quot;Up&quot;&#13;&#10;ELSE &quot;Down&quot;&#13;&#10;END'>
